# ARGOS ortam değişkenleri — `cp backend/.env.example backend/.env` ile başlayın

# ── Zorunlu (üretim) ─────────────────────────────────────────────
# ARGOS_JWT_SECRET=rastgele_uzun_metin   # ENV=production iken zorunlu
# ARGOS_ADMIN_USER=admin
# ARGOS_ADMIN_PASSWORD=guclu_sifre

# ── LLM (en az biri) ─────────────────────────────────────────────
# anthropic | gemini
LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Telegram (bildirimler) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Opsiyonel entegrasyonlar ───────────────────────────────────────
FIRECRAWL_API_KEY=
EXA_API_KEY=
SENTRY_DSN=

# ── Genel ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development

# Admin bootstrap: cp backend/.env.bootstrap.example backend/.env.bootstrap
